{{ attach_library('capital_azur/ca_footer') }}

{% set menu = simplify_menu(menu_id) %}

<footer class="border-t-2 border-gray-50 ">
  <div class="max-w-7xl mx-auto px-6">

    {# ── Row 1: social icons | nav links ────────────────────────── #}
    <div class="flex flex-col sm:flex-row items-center justify-between py-6 gap-4">

      {# Social icons #}
      <div class="flex items-center gap-5">
        <a href="{{ linkedin_url is not empty ? linkedin_url : 'https://www.linkedin.com' }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="LinkedIn" class="text-blue-400 hover:text-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>

        <a href="{{ youtube_url is not empty ? youtube_url : 'https://www.youtube.com' }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="YouTube" class="text-blue-400 hover:text-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
          </svg>
        </a>

        <a href="{{ twitter_url is not empty ? twitter_url : 'https://twitter.com' }}"
           target="_blank" rel="noopener noreferrer"
           aria-label="Twitter" class="text-blue-400 hover:text-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 4.557a9.83 9.83 0 01-2.828.775 4.932 4.932 0 002.165-2.724 9.864 9.864 0 01-3.127 1.195 4.916 4.916 0 00-3.594-1.555c-3.179 0-5.515 2.966-4.797 6.045A13.978 13.978 0 011.64 3.162a4.927 4.927 0 001.523 6.574 4.903 4.903 0 01-2.229-.616c-.054 2.281 1.581 4.415 3.949 4.89a4.935 4.935 0 01-2.224.084 4.928 4.928 0 004.6 3.419A9.9 9.9 0 010 19.54a13.94 13.94 0 007.548 2.212c9.142 0 14.307-7.721 13.995-14.646A10.025 10.025 0 0024 4.557z"/>
          </svg>
        </a>
      </div>

      {# Footer nav — from menu #}
      {% if menu.menu_tree is not empty %}
        <nav class="flex items-center flex-wrap justify-center">
          {% for item in menu.menu_tree %}
            {% if not loop.first %}
              <span class="text-gray-300 select-none mx-3">|</span>
            {% endif %}
            <a href="{{ item.url }}"
               class="text-[13px] font-semibold uppercase tracking-widest transition-colors
                      {% if item.in_active_trail %}text-blue-400{% else %}text-gray-700 hover:text-blue-400{% endif %}">
              {{ item.text }}
            </a>
          {% endfor %}
        </nav>
      {% endif %}

    </div>

    {# Divider #}
    <hr class="border-gray-200" />

    {# ── Row 2: copyright | agency ──────────────────────────────── #}
    <div class="flex flex-col sm:flex-row items-center justify-between py-4 gap-2">
      {% if copyright is not empty %}
        <span class="text-xs font-semibold text-blue-400 uppercase tracking-wider">
          {{ copyright }}
        </span>
      {% endif %}

      <div class="flex items-center gap-2 text-sm">
        {% if agency_text is not empty %}
          <span class="text-blue-400 font-medium">{{ agency_text }}</span>
        {% endif %}
        {% if agency_url is not empty %}
          <a href="{{ agency_url }}" target="_blank" rel="noopener noreferrer"
             class="flex items-center hover:opacity-80 transition-opacity">
            {% if agency_logo_url is not empty %}
              <img src="{{ agency_logo_url }}" alt="{{ agency_label }}" class="h-5 w-auto ml-1" />
            {% else %}
              <span class="inline-flex items-center gap-1 bg-blue-400 text-white font-bold uppercase tracking-widest text-[10px] px-2 py-0.5 ml-1">
                {{ agency_label }}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            {% endif %}
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</footer>
