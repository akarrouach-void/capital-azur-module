{{ attach_library('capital_azur/ca_about_us') }}

<div class="py-32 md:py-48 px-6">
  <div class="max-w-5xl mx-auto flex flex-col items-center text-center">

    {# ── Blue accent + title ─────────────────────────────────── #}
    <div class="flex flex-col items-center gap-6 mb-10">
      <span class="block w-16 h-[3px] bg-[#2b6df7] shrink-0"></span>
      {% if content.0.title is not empty %}
        <h2 class="text-3xl md:text-[42px] font-extrabold uppercase text-[#0B1526] leading-tight tracking-wide">
          {{ content.0.title }}
        </h2>
      {% endif %}
    </div>

    {# ── Description ─────────────────────────────────────────── #}
    {% if content.0.description is not empty %}
      <p class="text-gray-600 text-[17px] md:text-[19px] leading-relaxed mb-12 max-w-4xl">
        {{ content.0.description }}
      </p>
    {% endif %}

    {# ── CTA button (centered) ───────────────────────────────── #}
    {% if content.0.link.url is not empty and content.0.link.title is not empty %}
      <div>
        <a href="{{ content.0.link.url }}"
           class="inline-block px-10 py-4 bg-[#2b6df7] text-white text-base font-bold uppercase tracking-widest rounded shadow-md hover:bg-blue-700 transition">
          {{ content.0.link.title }}
        </a>
      </div>
    {% endif %}

  </div>
</div>
