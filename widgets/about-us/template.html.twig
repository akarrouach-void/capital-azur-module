{{ attach_library('capital_azur/ca_about_us') }}

<div class="py-14 px-6">
  <div class="max-w-3xl mx-auto">

    {# ── Blue accent + title ─────────────────────────────────── #}
    <div class="flex items-start gap-4 mb-6">
      <span class="mt-3 block w-12 h-[3px] bg-blue-600 shrink-0"></span>
      {% if content.0.title is not empty %}
        <h2 class="text-3xl font-extrabold uppercase text-gray-900 leading-tight tracking-wide">
          {{ content.0.title }}
        </h2>
      {% endif %}
    </div>

    {# ── Description ─────────────────────────────────────────── #}
    {% if content.0.description is not empty %}
      <p class="text-gray-700 text-base leading-relaxed mb-10">
        {{ content.0.description }}
      </p>
    {% endif %}

    {# ── CTA button (centered) ───────────────────────────────── #}
    {% if content.0.link.url is not empty and content.0.link.title is not empty %}
      <div class="flex justify-center">
        <a href="{{ content.0.link.url }}"
           class="px-6 py-3 bg-blue-600 text-white text-sm font-bold uppercase tracking-widest rounded-lg hover:bg-blue-700 transition">
          {{ content.0.link.title }}
        </a>
      </div>
    {% endif %}

  </div>
</div>
