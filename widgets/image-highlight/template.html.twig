{{ attach_library('capital_azur/ca_image_highlight') }}

{% set image_uri = (content.0.image.0 is defined) ? get_image(content.0.image.0) : '' %}
{% set image_url = image_uri is not empty ? file_url(image_uri) : '' %}
{% set bg_color = content.0.background_color is not empty ? content.0.background_color : '#1a6dd1' %}

<div style="background-color: {{ bg_color }};">
  <div class="flex flex-col md:flex-row items-center justify-between" style="max-width: 1400px; margin: 0 auto; min-height: 600px;">

    {# ── Image: top on mobile, left on desktop ───────────────── #}
    {% if image_url is not empty %}
      <div class="w-full md:w-1/2 flex justify-center items-center p-10 shrink-0">
        <img src="{{ image_url }}"
             alt="{{ content.0.title }}"
             class="w-full h-auto object-contain drop-shadow-2xl"
             style="max-height: 500px;" />
      </div>
    {% endif %}

    {# ── Text content ────────────────────────────────────────── #}
    <div class="flex-1 flex flex-col justify-center px-10 md:px-16 py-16 md:py-24">

      <div class="flex items-start gap-5 mb-8">
        <span class="mt-3 block w-10 h-[3px] bg-white shrink-0"></span>
        {% if content.0.title is not empty %}
          <h2 class="text-3xl md:text-[38px] font-extrabold uppercase text-white leading-tight tracking-wide">
            {{ content.0.title }}
          </h2>
        {% endif %}
      </div>

      {% if content.0.description is not empty %}
        <p class="text-white text-[17px] leading-relaxed mb-12 max-w-xl">
          {{ content.0.description }}
        </p>
      {% endif %}

      {% if content.0.link.url is not empty and content.0.link.title is not empty %}
        <div>
          <a href="{{ content.0.link.url }}"
             class="inline-block px-10 py-4 bg-white text-base font-bold uppercase tracking-widest rounded shadow-md hover:bg-gray-100 transition"
             style="color: {{ bg_color }};">
            {{ content.0.link.title }}
          </a>
        </div>
      {% endif %}

    </div>

  </div>
</div>
