{{ attach_library('capital_azur/ca_hero_slider') }}

<div class="relative overflow-hidden w-full" data-ca-slider>

  {# ── Slides track ───────────────────────────────────────────── #}
  <div class="flex transition-transform duration-700 ease-in-out" data-ca-slider-track>

    {% for item in content %}
      {% set image_uri = (item.image.0 is defined) ? get_image(item.image.0) : '' %}
      {% set image_url = image_uri is not empty ? file_url(image_uri) : '' %}
      {% set bg_color = item.background_color is not empty ? item.background_color : '#c4a882' %}

      <div class="relative min-w-full min-h-[600px] md:min-h-[700px] flex items-center"
           style="background-color: {{ bg_color }};">

        <div class="w-full px-12 flex items-center justify-between gap-10" style="max-width: 1400px; margin: 0 auto;">

          {# ── Left: white content card ─────────────────────────── #}
          <div class="bg-white shadow px-8 py-8 w-[500px] shrink-0 self-center z-10 " style="border-radius: 24px;">
            {# Blue accent bar + title #}
            <div class="flex items-start gap-4 mb-4">
              <span class="mt-3 block w-8 h-[2px] bg-blue-600 shrink-0"></span>
              <div class="flex-1">
                {% if item.title is not empty %}
                  <h2 class="text-3xl font-extrabold text-[#0B1526] leading-tight mb-2">{{ item.title }}</h2>
                {% endif %}
                
                {% if item.description is not empty %}
                  <p class="text-[17px] text-gray-700 leading-relaxed mb-4">{{ item.description }}</p>
                {% endif %}

                {% if item.link.url is not empty and item.link.title is not empty %}
                  <a href="{{ item.link.url }}"
                     class="inline-block px-8 py-3.5 bg-[#2b6df7] text-white text-base font-semibold rounded shadow-md hover:bg-blue-700 transition">
                    {{ item.link.title }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>

          {# ── Right: floating image ────────────────────────────── #}
          {% if image_url is not empty %}
            <div class="flex-1 flex justify-center items-center">
              <img src="{{ image_url }}"
                   alt="{{ item.title }}"
                   class="max-h-[500px] w-auto object-contain drop-shadow-2xl"
                   loading="lazy" />
            </div>
          {% endif %}

        </div>
      </div>
    {% endfor %}

  </div>

  {# ── Prev / Next arrows ─────────────────────────────────────── #}
  {% if content|length > 1 %}
    <button data-ca-slider-prev
            class="absolute left-3 top-1/2 -translate-y-1/2 z-20
                   w-8 h-8 flex items-center justify-center
                   text-blue-600 text-4xl font-thin
                   hover:text-blue-800 transition select-none"
            aria-label="Previous">&#8249;</button>

    <button data-ca-slider-next
            class="absolute right-3 top-1/2 -translate-y-1/2 z-20
                   w-8 h-8 flex items-center justify-center
                   text-blue-600 text-4xl font-thin
                   hover:text-blue-800 transition select-none"
            aria-label="Next">&#8250;</button>
  {% endif %}

  {# ── Progress bar ───────────────────────────────────────────── #}
  {% if content|length > 1 %}
    <div class="absolute bottom-0 left-0 w-full h-1 bg-white/20">
      <div class="h-full bg-blue-600 transition-all duration-700"
           data-ca-slider-progress
           style="width: {{ (1 / content|length * 100) }}%"></div>
    </div>
  {% endif %}

</div>
